// ────────────── SKYDATA H27G30Q profile ──────────────
// Active when SKYDATA is connected as DP-3.
// External 1440p panel on left, internal display on right.

output "DP-3" {
    mode "2560x1440@59.951"
    scale 1
    position x=0 y=0
    variable-refresh-rate on-demand=true
}

output "eDP-1" {
    mode "3072x1920@60.000"
    scale 1.3
    position x=2560 y=0
}

// Stale entry kept for legacy DP-1 hookup.
output "DP-1" {
    mode "2560x1440@359.979"
    scale 1
}
